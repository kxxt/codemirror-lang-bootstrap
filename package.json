{
  "name": "codemirror-lang-bootstrap",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite & npm run grammar:lang:dev",
    "build": "npm run grammar-build && tsc && vite build",
    "grammar:build": "npm run grammar:lang:build",
    "grammar:lang:build": "lezer-generator src/lang/lang.grammar -o src/lang/parser.mjs",
    "grammar:lang:dev": "node --watch-path src/lang/lang.grammar node_modules/.bin/lezer-generator src/lang/lang.grammar -o src/lang/parser.mjs"
  },
  "devDependencies": {
    "@lezer/generator": "^1.8.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@lezer/highlight": "^1.2.1",
    "@overleaf/codemirror-tree-view": "^0.1.3",
    "codemirror": "^6.0.2"
  }
}